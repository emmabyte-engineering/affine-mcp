# AFFiNE self-hosted instance URL
AFFINE_BASE_URL=http://localhost:3010

# Authentication (pick one method):

# Option 1: Email + password
AFFINE_EMAIL=user@example.com
AFFINE_PASSWORD=yourpassword

# Option 2: API bearer token
# AFFINE_API_TOKEN=your-token-here

# Option 3: Session cookie
# AFFINE_COOKIE=affine_session=...; affine_csrf=...
